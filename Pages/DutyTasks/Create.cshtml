@page
@model Student_Senate_Task_Wheel.Pages.DutyTasks.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>DutyTask</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="DutyTask.Title" class="control-label"></label>
                <input asp-for="DutyTask.Title" class="form-control" aria-required="true"/>
                <span asp-validation-for="DutyTask.Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DutyTask.Description" class="control-label"></label>
                <input asp-for="DutyTask.Description" class="form-control" />
                <span asp-validation-for="DutyTask.Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DutyTask.OrganizationId" class="control-label"></label>
                <select asp-for="DutyTask.OrganizationId" class ="form-control" asp-items="ViewBag.OrganizationId" ></select>
            </div>
            <div class="form-group">
                <label asp-for="DutyTask.Frequency" class="control-label"></label>
                <input asp-for="DutyTask.Frequency" class="form-control" />
                <span asp-validation-for="DutyTask.Frequency" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="DutyTask.IsActive" /> @Html.DisplayNameFor(model => model.DutyTask.IsActive)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
