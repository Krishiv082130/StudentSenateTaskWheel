@page
@model Student_Senate_Task_Wheel.Pages.Assignments.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>RotationAssignment</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="RotationAssignment.RotationAssignmentId" />
            <div class="form-group">
                <label asp-for="RotationAssignment.MemberId" class="control-label"></label>
                <select asp-for="RotationAssignment.MemberId" class="form-control" asp-items="ViewBag.MemberId" ></select>
                <span asp-validation-for="RotationAssignment.MemberId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RotationAssignment.DutyTaskId" class="control-label"></label>
                <select asp-for="RotationAssignment.DutyTaskId" class="form-control" asp-items="ViewBag.DutyTaskId" ></select>
                <span asp-validation-for="RotationAssignment.DutyTaskId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RotationAssignment.WeekStartDate" class="control-label"></label>
                <input asp-for="RotationAssignment.WeekStartDate" class="form-control" />
                <span asp-validation-for="RotationAssignment.WeekStartDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RotationAssignment.Status" class="control-label"></label>
                <input asp-for="RotationAssignment.Status" class="form-control" />
                <span asp-validation-for="RotationAssignment.Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RotationAssignment.CompletedOn" class="control-label"></label>
                <input asp-for="RotationAssignment.CompletedOn" class="form-control" />
                <span asp-validation-for="RotationAssignment.CompletedOn" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
