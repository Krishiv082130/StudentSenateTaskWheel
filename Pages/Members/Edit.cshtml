@page
@model Student_Senate_Task_Wheel.Pages.Members.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Member</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Member.MemberId" />
            <div class="form-group">
                <label asp-for="Member.OrganizationId" class="control-label"></label>
                <select asp-for="Member.OrganizationId" class="form-control" asp-items="ViewBag.OrganizationId" ></select>
                <span asp-validation-for="Member.OrganizationId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Member.RoleId" class="control-label"></label>
                <select asp-for="Member.RoleId" class="form-control" asp-items="ViewBag.RoleId" ></select>
                <span asp-validation-for="Member.RoleId" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Member.IsOrgAdmin" /> @Html.DisplayNameFor(model => model.Member.IsOrgAdmin)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
